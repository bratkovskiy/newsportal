---
import AdSlot from '../components/AdSlot.astro';

const hasLeft = !!Astro.slots.left;
const hasRight = !!Astro.slots.right;
---
<div class="container mx-auto px-4 py-8">
  <div class="flex flex-col gap-8 lg:grid lg:grid-cols-[minmax(0,1fr)_260px]">
    <aside class="hidden">
      {hasLeft && <slot name="left" />}
    </aside>

    <div class="lg:col-start-1">
      <slot />
    </div>

    <aside class="lg:col-start-2 space-y-6">
      {hasRight ? (
        <slot name="right" />
      ) : (
        <AdSlot placementKey="sidebar_default" />
      )}
    </aside>
  </div>
</div>
