---
import BaseLayout from './BaseLayout.astro'; // Assuming a BaseLayout exists
import MainColumns from './MainColumns.astro';
import AdSlot from '../components/AdSlot.astro';
import { generateArticleTitle, generateArticleDescription } from '../config/seo';

const {
  title,
  excerpt,
  author,
  publishedDate,
  coverImage,
  coverImageAlt,
  fallbackImageUrl,
  category,
  coverCaption,
  locale = 'ru',
} = Astro.props;

const dateLocale = locale === 'en' ? 'en-US' : 'ru-RU';
const _d = publishedDate instanceof Date ? publishedDate : new Date(publishedDate);
const formattedDate = new Intl.DateTimeFormat(dateLocale, { dateStyle: 'long' }).format(_d);

// Generate SEO meta tags
const metaTitle = await generateArticleTitle(title);
const metaDescription = await generateArticleDescription(excerpt);
---

<BaseLayout title={metaTitle} description={metaDescription}>
  <MainColumns>
    <article class="max-w-4xl mx-auto py-8 lg:py-10">
      <div class="mb-6">
        <slot name="breadcrumbs" />
      </div>
      <header class="mb-10">
        <div class="mb-6">
          <h1 class="text-3xl md:text-4xl lg:text-5xl font-semibold tracking-tight text-foreground">
            {title}
          </h1>
          {excerpt && (
            <p class="text-base md:text-lg text-muted mt-4 max-w-2xl">
              {excerpt}
            </p>
          )}
        </div>
        <div class="flex flex-wrap items-center gap-3 text-xs text-muted">
          <span>{typeof author === "object" ? author?.name : author}</span>
          <span class="w-px h-3 bg-border" aria-hidden="true"></span>
          <time datetime={publishedDate instanceof Date ? publishedDate.toISOString() : publishedDate}>{formattedDate}</time>
        </div>
        <div class="mt-8 rounded-card overflow-hidden shadow-card">
          <img
            src={coverImage}
            alt={coverImageAlt}
            width={1200}
            height={600}
            fetchpriority="high"
            class="w-full h-auto object-cover aspect-video"
            onerror={`this.onerror=null; this.src='${fallbackImageUrl}';`}
          />
        </div>
        {coverCaption && (
          <p class="mt-3 text-xs text-muted max-w-2xl">
            {coverCaption}
          </p>
        )}
      </header>

      <div class="prose prose-lg article-prose max-w-4xl w-full">
        <slot /> <!-- Article content goes here -->
      </div>
      
      <slot name="related" /> <!-- Related articles block -->
    </article>

    <div slot="right" class="space-y-6">
      <slot name="right" />
      <AdSlot placementKey="article_sidebar" />
    </div>
  </MainColumns>
</BaseLayout>

<style is:global>
  .article-prose {
    color: hsl(var(--foreground));
  }

  .article-prose p {
    margin-top: 1em;
    margin-bottom: 1em;
    line-height: 1.8;
    font-size: 1.05rem;
  }

  .article-prose h1,
  .article-prose h2,
  .article-prose h3,
  .article-prose h4 {
    font-weight: 700;
    line-height: 1.3;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }

  .article-prose h2 {
    font-size: 1.8rem;
  }

  .article-prose h3 {
    font-size: 1.4rem;
  }

  .article-prose h4 {
    font-size: 1.2rem;
    text-transform: none;
    letter-spacing: 0.02em;
  }

  .article-prose ul,
  .article-prose ol {
    padding-left: 1.5rem;
    margin: 1rem 0;
  }

  .article-prose li + li {
    margin-top: 0.25rem;
  }

  .article-prose img {
    display: block;
    max-width: 100%;
    height: auto;
    margin: 2rem auto;
    border-radius: 0.75rem;
    box-shadow: 0 18px 45px rgba(15, 23, 42, 0.25);
  }

  .article-prose figure {
    margin: 2.5rem 0;
    text-align: center;
  }

  .article-prose figure img {
    margin-bottom: 0.75rem;
  }

  .article-prose figcaption {
    font-size: 0.875rem;
    color: hsl(var(--muted-foreground));
  }

  .article-prose blockquote {
    margin: 2rem 0;
    padding-left: 1.25rem;
    border-left: 3px solid hsl(var(--accent));
    font-style: italic;
    color: hsl(var(--muted-foreground));
  }

  .article-prose blockquote p {
    margin: 0.25rem 0;
  }

  .article-prose code {
    padding: 0.15rem 0.35rem;
    border-radius: 0.25rem;
    background-color: hsl(var(--muted));
    font-size: 0.9em;
  }

  .article-prose pre {
    padding: 1rem 1.25rem;
    border-radius: 0.75rem;
    background-color: #020617;
    color: #e5e7eb;
    overflow-x: auto;
    font-size: 0.9rem;
  }

  @media (max-width: 768px) {
    .article-prose {
      font-size: 0.98rem;
    }

    .article-prose h2 {
      font-size: 1.5rem;
    }

    .article-prose h3 {
      font-size: 1.25rem;
    }
  }
</style>
