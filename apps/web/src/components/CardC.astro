---
import { Image } from 'astro:assets';

export interface Props {
  href: string;
  title: string;
  imageUrl: string;
  imageAlt: string;
}

const { href, title, imageUrl, imageAlt } = Astro.props;
---

<a href={href} class="flex items-center group p-2 rounded-card hover:bg-gray-100 transition-colors duration-200">
  <div class="w-16 h-16 flex-shrink-0 mr-4">
    <Image
      src={imageUrl}
      alt={imageAlt}
      width={100}
      height={100}
      format="avif"
      quality={75}
      class="w-full h-full object-cover rounded-image"
    />
  </div>
  <div>
    <h4 class="text-sm font-semibold text-foreground leading-tight group-hover:text-accent transition-colors duration-200">{title}</h4>
  </div>
</a>
