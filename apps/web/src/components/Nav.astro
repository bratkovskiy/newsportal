---
// apps/web/src/components/Nav.astro
// Липкая навигация с категориями

// Категории подтягиваются из CMS
const CMS_URL = import.meta.env.CMS_URL ?? 'http://localhost:3000';

let categories = [];
try {
  const res = await fetch(`${CMS_URL}/api/categories?limit=10&sort=name`);
  const { docs } = await res.json();
  categories = docs.map((cat: any) => ({
    name: cat.name,
    slug: cat.slug,
  }));
} catch (error) {
  console.error('Failed to fetch categories:', error);
}

const currentPath = Astro.url.pathname;
---

<header class="nav-wrap">
  <nav class="nav" aria-label="Main navigation">
    <a class="nav-logo" href="/">Moda Review</a>

    <!-- Desktop cats -->
    <ul class="nav-cats" role="list">
      {categories.map(cat => (
        <li>
          <a
            href={`/categories/${cat.slug}`}
            class:list={['nav-cat', { 'nav-cat--active': currentPath.startsWith(`/categories/${cat.slug}`) }]}
          >
            {cat.name}
          </a>
        </li>
      ))}
    </ul>

    <!-- Mobile burger -->
    <button class="nav-burger" aria-label="Open menu" aria-expanded="false" aria-controls="mobile-menu">
      <span></span><span></span><span></span>
    </button>
  </nav>

  <!-- Mobile menu -->
  <div class="mobile-menu" id="mobile-menu" hidden>
    <ul role="list">
      {categories.map(cat => (
        <li>
          <a href={`/categories/${cat.slug}`} class="mobile-cat">{cat.name}</a>
        </li>
      ))}
    </ul>
  </div>
</header>

<script>
  const burger = document.querySelector('.nav-burger') as HTMLButtonElement;
  const menu   = document.getElementById('mobile-menu') as HTMLDivElement;

  burger?.addEventListener('click', () => {
    const open = burger.getAttribute('aria-expanded') === 'true';
    burger.setAttribute('aria-expanded', String(!open));
    burger.classList.toggle('is-open', !open);
    menu.hidden = open;
  });
</script>

<style>
  .nav-wrap {
    position: sticky;
    top: 0;
    z-index: 200;
    background: var(--cream);
    border-bottom: 1px solid var(--line);
  }

  .nav {
    max-width: var(--wide-w);
    margin: 0 auto;
    padding: 0 1.25rem;
    height: var(--nav-h);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
  }

  /* Logo */
  .nav-logo {
    font-family: var(--font-display);
    font-size: 1.15rem;
    letter-spacing: .06em;
    text-transform: uppercase;
    color: var(--ink);
    text-decoration: none;
    flex-shrink: 0;
    white-space: nowrap;
  }

  /* Desktop categories */
  .nav-cats {
    display: flex;
    gap: .25rem;
    list-style: none;
    overflow: hidden;
  }
  .nav-cat {
    font-size: .72rem;
    font-weight: 500;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: var(--text-light);
    text-decoration: none;
    padding: .3rem .6rem;
    border-radius: var(--radius-sm);
    transition: color .15s, background .15s;
    white-space: nowrap;
  }
  .nav-cat:hover,
  .nav-cat--active {
    color: var(--accent);
    background: var(--accent-light);
  }

  /* Burger */
  .nav-burger {
    display: none;
    flex-direction: column;
    gap: 5px;
    padding: .4rem;
    flex-shrink: 0;
  }
  .nav-burger span {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--ink);
    border-radius: 2px;
    transition: transform .25s var(--ease-out), opacity .2s;
  }
  .nav-burger.is-open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .nav-burger.is-open span:nth-child(2) { opacity: 0; }
  .nav-burger.is-open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  /* Mobile menu */
  .mobile-menu {
    border-top: 1px solid var(--line);
    background: var(--cream);
    padding: 1rem 1.25rem 1.25rem;
  }
  .mobile-menu ul { list-style: none; display: flex; flex-direction: column; gap: .1rem; }
  .mobile-cat {
    display: block;
    padding: .6rem .5rem;
    font-size: .8rem;
    font-weight: 500;
    letter-spacing: .08em;
    text-transform: uppercase;
    color: var(--text-light);
    text-decoration: none;
    border-bottom: 1px solid var(--line);
    transition: color .15s;
  }
  .mobile-cat:hover { color: var(--accent); }

  @media (max-width: 680px) {
    .nav-cats  { display: none; }
    .nav-burger { display: flex; }
  }
</style>
