---
export interface Props {
  href: string;
  title: string;
  imageUrl: string;
  imageAlt: string;
  category: string;
  authorName: string;
}

const { href, title, imageUrl, imageAlt, category, authorName } = Astro.props;
---

<a href={href} class="flex flex-col sm:flex-row items-center group bg-background rounded-card overflow-hidden shadow-sm hover:shadow-card transition-shadow duration-300">
  <div class="w-full sm:w-1/3 flex-shrink-0">
    <img
      src={imageUrl}
      alt={imageAlt}
      width={400}
      height={400}
      loading="lazy"
      class="w-full h-auto object-cover aspect-square transition-transform duration-300 group-hover:scale-105"
    />
  </div>
  <div class="p-4 sm:p-6 flex flex-col justify-between">
    <div>
      <span class="text-accent text-xs font-bold uppercase mb-2 block">{category}</span>
      <h3 class="text-md sm:text-lg font-bold text-foreground mb-2">{title}</h3>
    </div>
    <p class="text-sm text-muted mt-4">by {authorName}</p>
  </div>
</a>
