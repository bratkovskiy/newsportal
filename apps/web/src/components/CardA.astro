---
export interface Props {
  href: string;
  title: string;
  excerpt: string;
  imageUrl: string;
  imageAlt: string;
  category: string;
}

const { href, title, excerpt, imageUrl, imageAlt, category } = Astro.props;
---

<a href={href} class="block group rounded-card overflow-hidden shadow-card hover:shadow-lg transition-shadow duration-300 bg-background">
  <div class="relative">
    <img
      src={imageUrl}
      alt={imageAlt}
      width={1200}
      height={675}
      loading="lazy"
      class="w-full h-auto object-cover aspect-video transition-transform duration-300 group-hover:scale-105"
    />
    <div class="absolute top-4 left-4 text-xs font-bold uppercase px-3 py-1 rounded-button bg-accent text-white">
      {category}
    </div>
  </div>
  <div class="p-4 sm:p-6">
    <h3 class="text-lg sm:text-xl font-bold text-foreground mb-2">{title}</h3>
    <p class="text-sm sm:text-base text-muted">{excerpt}</p>
  </div>
</a>
