---
import BaseLayout from '../../layouts/BaseLayout.astro';
import MainColumns from '../../layouts/MainColumns.astro';

const CMS_URL = import.meta.env.CMS_URL || 'http://cms:3000';

let categories: Array<{ id: string; name: string; slug: string; metaTitle?: string; metaDescription?: string }> = [];

try {
  const response = await fetch(`${CMS_URL}/api/categories?limit=1000&sort=name`);
  if (response.ok) {
    const data = await response.json();
    categories = (data.docs || []).map((cat: any) => ({
      id: cat.id,
      name: cat.name,
      slug: cat.slug,
      metaTitle: cat.metaTitle,
      metaDescription: cat.metaDescription,
    }));
  }
} catch (error) {
  console.error('Error fetching categories:', error);
}

const metaTitle = 'Все категории - LADY.NEWS';
const metaDescription = 'Полный список категорий на LADY.NEWS';
---

<BaseLayout title={metaTitle} description={metaDescription}>
  <MainColumns>
    <!-- Breadcrumbs -->
    <nav class="text-sm mb-6">
      <a href="/" class="text-muted hover:text-accent">Главная</a>
      <span class="mx-2">/</span>
      <span>Категории</span>
    </nav>

    <h1 class="text-3xl font-bold text-foreground mb-8">Все категории</h1>

    {categories.length > 0 ? (
      <div class="flex flex-wrap gap-3">
        {categories.map((category) => (
          <a
            href={`/categories/${category.slug}`}
            class="inline-block px-4 py-2 bg-background border border-border rounded-full text-sm font-medium text-foreground hover:bg-accent hover:text-background hover:border-accent transition-all duration-200 shadow-sm hover:shadow-md"
          >
            {category.name}
          </a>
        ))}
      </div>
    ) : (
      <p class="text-muted">Категории не найдены</p>
    )}
  </MainColumns>
</BaseLayout>
