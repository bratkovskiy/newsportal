---
import BaseLayout from '../../layouts/BaseLayout.astro';
import MainColumns from '../../layouts/MainColumns.astro';
import { generateCategoryTitle, generateCategoryDescription } from '../../config/seo';
import { getCmsEnv } from '../../utils/cmsEnv';

const { cmsUrl: CMS_URL, placeholderImageUrl: PLACEHOLDER_IMAGE_URL } = getCmsEnv();
const PAGE_LIMIT = 50;

const { slug } = Astro.params;
const url = Astro.url;
const currentPage = Number(url.searchParams.get('page') || '1');

let category = null;
let categoryId = null;

try {
  const categoriesResponse = await fetch(`${CMS_URL}/api/categories?where[slug][equals]=${slug}&limit=1`);
  if (categoriesResponse.ok) {
    const categoriesData = await categoriesResponse.json();
    const categories = categoriesData.docs || [];
    if (categories.length > 0) {
      category = categories[0];
      categoryId = category.id;
    }
  }
} catch (error) {
  console.error('Error fetching category:', error);
}

if (!category || !categoryId) {
  return Astro.redirect('/404');
}

let articles = [];
let pagination: { page: number; totalPages: number; totalDocs: number } = {
  page: currentPage,
  totalPages: 1,
  totalDocs: 0,
};

type SiteLanguage = 'ru' | 'en';
type SiteSettings = {
  currentLanguage?: SiteLanguage;
};

let siteSettings: SiteSettings | null = null;
try {
  const res = await fetch(`${CMS_URL}/api/globals/site-settings`);
  if (res.ok) {
    siteSettings = (await res.json()) as SiteSettings;
  }
} catch (error) {
  console.error('Failed to fetch site settings:', error);
}

const currentLanguage: SiteLanguage = siteSettings?.currentLanguage === 'en' ? 'en' : 'ru';
const defaultAuthorName = currentLanguage === 'en' ? 'Editorial team' : 'Редакция';
const breadcrumbsHomeLabel = currentLanguage === 'en' ? 'Home' : 'Главная';
const breadcrumbsCategoriesLabel = currentLanguage === 'en' ? 'Categories' : 'Категории';
const sectionAllArticlesLabel = currentLanguage === 'en' ? 'All articles' : 'Все статьи';
const paginationPrevLabel = currentLanguage === 'en' ? '← Previous' : '← Назад';
const paginationNextLabel = currentLanguage === 'en' ? 'Next →' : 'Вперёд →';
const paginationAriaLabel = currentLanguage === 'en' ? 'Pagination' : 'Пагинация';
const emptyStateText = currentLanguage === 'en'
  ? 'No published articles in this category yet.'
  : 'В этой категории пока нет опубликованных статей.';

const paginationInfoText = (page: number, total: number) =>
  currentLanguage === 'en' ? `Page ${page} of ${total}` : `Страница ${page} из ${total}`;

const formatArticleCount = (count: number) => {
  if (count <= 0) {
    return '';
  }
  if (currentLanguage === 'en') {
    return `${count} ${count === 1 ? 'article' : 'articles'}`;
  }
  const mod100 = count % 100;
  const mod10 = count % 10;
  let word = 'статей';
  if (mod100 > 10 && mod100 < 20) {
    word = 'статей';
  } else if (mod10 === 1) {
    word = 'статья';
  } else if (mod10 >= 2 && mod10 <= 4) {
    word = 'статьи';
  }
  return `${count} ${word}`;
};

try {
  const articlesResponse = await fetch(
    `${CMS_URL}/api/articles?where[categories][equals]=${categoryId}&where[status][equals]=published&sort=-publishedDate&page=${currentPage}&limit=${PAGE_LIMIT}`
  );
  if (articlesResponse.ok) {
    const articlesData = await articlesResponse.json();
    pagination = {
      page: typeof articlesData.page === 'number' ? articlesData.page : currentPage,
      totalPages: typeof articlesData.totalPages === 'number' ? articlesData.totalPages : 1,
      totalDocs: typeof articlesData.totalDocs === 'number' ? articlesData.totalDocs : (Array.isArray(articlesData.docs) ? articlesData.docs.length : 0),
    };

    articles = (articlesData.docs || []).map((article: any) => {
      let imageUrl = PLACEHOLDER_IMAGE_URL;
      if (article.feedImageUrl) {
        imageUrl = article.feedImageUrl;
      } else if (article.coverImage) {
        if (typeof article.coverImage === 'object' && article.coverImage?.url) {
          imageUrl = article.coverImage.url.startsWith('http')
            ? article.coverImage.url
            : `${CMS_URL}${article.coverImage.url}`;
        } else if (typeof article.coverImage === 'number' || typeof article.coverImage === 'string') {
          imageUrl = `${CMS_URL}/api/media/${article.coverImage}`;
        }
      }

      let authorName = defaultAuthorName;
      if (article.author && typeof article.author === 'object' && article.author?.name) {
        authorName = article.author.name;
      }

      const articleSlug = article.slug || '';
      const articleId = article.id != null ? String(article.id) : '';
      const href = articleSlug && articleId
        ? `/article/${articleSlug}-${articleId}.html`
        : articleSlug ? `/article/${articleSlug}` : articleId ? `/article/${articleId}` : '/';

      return {
        href,
        title: article.title,
        excerpt: article.excerpt || '',
        imageUrl,
        imageAlt: article.title,
        fallbackImageUrl: PLACEHOLDER_IMAGE_URL,
        category: category.name,
        authorName,
        publishedDate: article.publishedDate,
      };
    });
  }
} catch (error) {
  console.error('Error fetching articles:', error);
}

const articleCount = articles.length;
let metaTitle = category.metaTitle as string | undefined;
let metaDescription = category.metaDescription as string | undefined;
if (!metaTitle) metaTitle = await generateCategoryTitle(category.name, articleCount);
if (!metaDescription) metaDescription = await generateCategoryDescription(category.name, articleCount);

// Split: first 2 featured, rest in grid
const featuredArticles = articles.slice(0, 2);
const gridArticles = articles.slice(2);
---

<BaseLayout title={metaTitle} description={metaDescription}>
  <MainColumns>

    <!-- Breadcrumbs -->
    <nav class="cat-breadcrumb">
      <a href="/">{breadcrumbsHomeLabel}</a>
      <span>/</span>
      <a href="/categories">{breadcrumbsCategoriesLabel}</a>
      <span>/</span>
      <span class="cat-breadcrumb__current">{category.name}</span>
    </nav>

    <!-- Category header -->
    <div class="cat-header">
      <span class="cat-header__tag">{category.name}</span>
      <h1 class="cat-header__title">{category.name}</h1>
      {pagination.totalDocs > 0 && (
        <p class="cat-header__count">{formatArticleCount(pagination.totalDocs)}</p>
      )}
    </div>

    {articles.length > 0 ? (
      <>
        <!-- Featured top 2 -->
        {featuredArticles.length > 0 && (
          <div class="cat-featured">
            {featuredArticles.map((article: any, i: number) => (
              <a href={article.href} class="cat-featured__item group">
                <div class="cat-featured__img-wrap">
                  <img
                    src={article.imageUrl}
                    alt={article.imageAlt}
                    width={560}
                    height={315}
                    loading={i === 0 ? 'eager' : 'lazy'}
                    class="cat-featured__img"
                    onerror={`this.onerror=null;this.src='${PLACEHOLDER_IMAGE_URL}'`}
                  />
                </div>
                <div class="cat-featured__body">
                  <span class="cat-tag">{article.category}</span>
                  <h2 class="cat-featured__title">{article.title}</h2>
                  {article.excerpt && (
                    <p class="cat-featured__excerpt">{article.excerpt}</p>
                  )}
                  <p class="cat-featured__meta">{article.authorName}</p>
                </div>
              </a>
            ))}
          </div>
        )}

        <!-- Rest of articles -->
        {gridArticles.length > 0 && (
          <section class="cat-grid-section">
            <div class="cat-section-label">
              <span>{sectionAllArticlesLabel}</span>
              <span class="cat-section-label__line"></span>
            </div>
            <div class="cat-grid">
              {gridArticles.map((article: any) => (
                <a href={article.href} class="cat-news-item group">
                  <div class="cat-news-item__img-wrap">
                    <img
                      src={article.imageUrl}
                      alt={article.imageAlt}
                      width={160}
                      height={107}
                      loading="lazy"
                      class="cat-news-item__img"
                      onerror={`this.onerror=null;this.src='${article.fallbackImageUrl}'`}
                    />
                  </div>
                  <div class="cat-news-item__body">
                    <span class="cat-tag">{article.category}</span>
                    <h3 class="cat-news-item__title">{article.title}</h3>
                    <p class="cat-news-item__meta">{article.authorName}</p>
                  </div>
                </a>
              ))}
            </div>
          </section>
        )}

        <!-- Pagination -->
        {pagination.totalPages > 1 && (
          <nav class="cat-pagination" aria-label={paginationAriaLabel}>
            {pagination.page > 1 && (
              <a
                href={pagination.page - 1 === 1 ? `/categories/${slug}` : `/categories/${slug}?page=${pagination.page - 1}`}
                class="cat-pagination__btn"
              >
                {paginationPrevLabel}
              </a>
            )}
            <span class="cat-pagination__info">
              {paginationInfoText(pagination.page, pagination.totalPages)}
            </span>
            {pagination.page < pagination.totalPages && (
              <a
                href={`/categories/${slug}?page=${pagination.page + 1}`}
                class="cat-pagination__btn"
              >
                {paginationNextLabel}
              </a>
            )}
          </nav>
        )}
      </>
    ) : (
      <div class="cat-empty">
        <p>{emptyStateText}</p>
      </div>
    )}

  </MainColumns>
</BaseLayout>

<style>
:root {
  --cat-bg:       #faf9f7;
  --cat-surface:  #ffffff;
  --cat-surface2: #f3f1ec;
  --cat-text:     #1a1a18;
  --cat-text2:    #4a4a45;
  --cat-muted:    #8a8a82;
  --cat-accent:   var(--accent, #2d6a4f);
  --cat-border:   #e2ddd6;
  --cat-border2:  #ccc8c0;
  --cat-radius:   6px;
  --cat-serif:    'Lora', Georgia, 'Times New Roman', serif;
}

/* Breadcrumb */
.cat-breadcrumb {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 12px;
  color: var(--cat-muted);
  margin-bottom: 1.25rem;
}
.cat-breadcrumb a {
  color: var(--cat-muted);
  text-decoration: none;
  transition: color 0.15s;
}
.cat-breadcrumb a:hover { color: var(--cat-accent); }
.cat-breadcrumb__current { color: var(--cat-text2); }

/* Category header */
.cat-header {
  padding-bottom: 1.25rem;
  margin-bottom: 1.5rem;
  border-bottom: 1px solid var(--cat-border);
}
.cat-header__tag {
  display: inline-block;
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--cat-accent);
  margin-bottom: 8px;
}
.cat-header__title {
  font-family: var(--cat-serif);
  font-size: clamp(24px, 4vw, 32px);
  font-weight: 600;
  line-height: 1.2;
  color: var(--cat-text);
  margin-bottom: 6px;
}
.cat-header__count {
  font-size: 12px;
  color: var(--cat-muted);
}

/* Category tag pill */
.cat-tag {
  display: inline-block;
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--cat-accent);
  margin-bottom: 6px;
}

/* Featured 2-up */
.cat-featured {
  display: grid;
  grid-template-columns: 1fr;
  gap: 1px;
  background: var(--cat-border);
  border: 1px solid var(--cat-border);
  border-radius: var(--cat-radius);
  overflow: hidden;
  margin-bottom: 2rem;
}
@media (min-width: 700px) {
  .cat-featured { grid-template-columns: 1fr 1fr; }
}

.cat-featured__item {
  background: var(--cat-surface);
  display: flex;
  flex-direction: column;
  text-decoration: none;
  transition: background 0.15s;
}
.cat-featured__item:hover { background: var(--cat-surface2); }

.cat-featured__img-wrap {
  overflow: hidden;
  flex-shrink: 0;
}
.cat-featured__img {
  width: 100%;
  aspect-ratio: 16 / 9;
  object-fit: cover;
  display: block;
  transition: transform 0.4s ease;
}
.cat-featured__item:hover .cat-featured__img { transform: scale(1.03); }

.cat-featured__body {
  padding: 1rem 1.25rem 1.25rem;
  display: flex;
  flex-direction: column;
  flex: 1;
}
.cat-featured__title {
  font-family: var(--cat-serif);
  font-size: clamp(16px, 2vw, 20px);
  font-weight: 600;
  line-height: 1.32;
  color: var(--cat-text);
  margin-bottom: 8px;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.cat-featured__excerpt {
  font-size: 13px;
  color: var(--cat-text2);
  line-height: 1.65;
  margin-bottom: 10px;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.cat-featured__meta {
  font-size: 11px;
  color: var(--cat-muted);
  margin-top: auto;
}

/* Section label */
.cat-section-label {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 0;
  padding-bottom: 0.875rem;
  border-bottom: 1px solid var(--cat-border);
}
.cat-section-label span:first-child {
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--cat-muted);
  white-space: nowrap;
}
.cat-section-label__line {
  flex: 1;
  height: 1px;
  background: var(--cat-border);
}

.cat-grid-section { margin-bottom: 2rem; }

/* News item list */
.cat-grid {
  display: flex;
  flex-direction: column;
}

.cat-news-item {
  display: flex;
  gap: 14px;
  padding: 1rem 0;
  border-bottom: 1px solid var(--cat-border);
  text-decoration: none;
  transition: opacity 0.15s;
}
.cat-news-item:last-child { border-bottom: none; }
.cat-news-item:hover { opacity: 0.75; }

.cat-news-item__img-wrap {
  flex-shrink: 0;
  width: 110px;
  height: 74px;
  border-radius: var(--cat-radius);
  overflow: hidden;
}
@media (min-width: 600px) {
  .cat-news-item__img-wrap { width: 140px; height: 93px; }
}
.cat-news-item__img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 0.3s ease;
}
.cat-news-item:hover .cat-news-item__img { transform: scale(1.04); }

.cat-news-item__body {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  justify-content: center;
}
.cat-news-item__title {
  font-family: var(--cat-serif);
  font-size: 15px;
  font-weight: 600;
  line-height: 1.42;
  color: var(--cat-text);
  margin-bottom: 5px;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.cat-news-item__meta {
  font-size: 11px;
  color: var(--cat-muted);
}

/* Pagination */
.cat-pagination {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16px;
  margin-top: 2rem;
  padding-top: 1.5rem;
  border-top: 1px solid var(--cat-border);
}
.cat-pagination__btn {
  font-size: 12px;
  font-weight: 500;
  color: var(--cat-text2);
  border: 1px solid var(--cat-border2);
  border-radius: 40px;
  padding: 8px 20px;
  text-decoration: none;
  transition: border-color 0.15s, color 0.15s;
}
.cat-pagination__btn:hover {
  border-color: var(--cat-accent);
  color: var(--cat-accent);
}
.cat-pagination__info {
  font-size: 12px;
  color: var(--cat-muted);
}

/* Empty state */
.cat-empty {
  text-align: center;
  padding: 4rem 0;
}
.cat-empty p {
  font-size: 15px;
  color: var(--cat-muted);
}
</style>