---
import BaseLayout from '../layouts/BaseLayout.astro';
import CardA from '../components/CardA.astro';
import CardFeed from '../components/CardFeed.astro';
import MainColumns from '../layouts/MainColumns.astro';
import { generateHomeTitle, generateHomeDescription, getBrandName } from '../config/seo';
import { getCmsEnv } from '../utils/cmsEnv';

const { cmsUrl: CMS_URL, publicCmsUrl: PUBLIC_CMS_URL, placeholderImageUrl: PLACEHOLDER_IMAGE_URL } = getCmsEnv();
const PAGE_LIMIT = 100;

type PayloadArticle = {
  id: string;
  title?: string;
  slug?: string;
  excerpt?: string;
  publishedDate?: string;
  author?: any;
  coverImage?: any;
  categories?: any[];
  tags?: any[];
  feedImageUrl?: string;
  viewCount?: number;
  homeMainBlock?: boolean;
  homeTop?: boolean;
  homeMustRead?: boolean;
};

type ArticlesResponse = {
  docs?: PayloadArticle[];
};

type TagItem = {
  id: string;
  name: string;
  slug: string;
};

type HomeCategory = {
  id: string;
  name: string;
  slug: string;
};

type HomeArticle = {
  id: string;
  href: string;
  title: string;
  excerpt: string;
  imageUrl: string;
  imageAlt: string;
  fallbackImageUrl: string;
  category: string;
  authorName: string;
  publishedDate?: string;
  viewCount: number;
  homeMainBlock?: boolean;
  homeTop?: boolean;
  homeMustRead?: boolean;
  categories?: any[];
};

async function fetchArticles(): Promise<PayloadArticle[]> {
  try {
    const url = `${CMS_URL}/api/articles?where[status][equals]=published&depth=1&sort=-publishedDate&page=1&limit=${PAGE_LIMIT}`;
    const res = await fetch(url);
    if (!res.ok) { console.error('Failed to fetch articles:', res.status); return []; }
    const data = (await res.json()) as ArticlesResponse;
    return Array.isArray(data?.docs) ? data.docs : [];
  } catch (e) { console.error('Error fetching articles:', e); return []; }
}

async function fetchHomeCategories(): Promise<HomeCategory[]> {
  try {
    const url = `${CMS_URL}/api/categories?where[showOnHome][equals]=true&limit=20&sort=name`;
    const res = await fetch(url);
    if (!res.ok) { console.error('Failed to fetch home categories:', res.status); return []; }
    const data = await res.json();
    const docs = Array.isArray(data?.docs) ? data.docs : [];
    return docs.map((cat: any) => ({ id: String(cat.id), name: cat.name ?? '', slug: cat.slug ?? '' }));
  } catch (e) { console.error('Error fetching home categories:', e); return []; }
}

async function fetchTags(): Promise<TagItem[]> {
  try {
    const url = `${CMS_URL}/api/tags?limit=50&sort=name`;
    const res = await fetch(url);
    if (!res.ok) { console.error('Failed to fetch tags:', res.status); return []; }
    const data = await res.json();
    const docs = Array.isArray(data?.docs) ? data.docs : [];
    return docs.map((tag: any) => ({ id: String(tag.id), name: tag.name ?? '', slug: tag.slug ?? '' }));
  } catch (e) { console.error('Error fetching tags:', e); return []; }
}

function buildArticlePath(article: PayloadArticle): string {
  const slug = article.slug ?? '';
  const id = article.id ? String(article.id) : '';
  if (slug && id) return `/article/${slug}-${id}.html`;
  if (slug) return `/article/${slug}`;
  if (id) return `/article/${id}`;
  return '/';
}

function getCoverImage(article: PayloadArticle): { url: string; alt: string } {
  if (article.feedImageUrl) return { url: article.feedImageUrl, alt: article.title ?? '' };
  const coverImage = article.coverImage && typeof article.coverImage === 'object' ? article.coverImage : null;
  const url = coverImage?.url ?? PLACEHOLDER_IMAGE_URL;
  const alt = coverImage?.alt ?? (article.title ?? '');
  return { url, alt };
}

function getCategoryName(article: PayloadArticle): string {
  if (!Array.isArray(article.categories) || article.categories.length === 0) return '';
  const first = article.categories[0];
  if (first && typeof first === 'object') return first.name ?? '';
  return '';
}

function getAuthorName(article: PayloadArticle): string {
  if (article.author && typeof article.author === 'object') return article.author.name ?? 'Unknown';
  return 'Unknown';
}

function getPrimaryTagName(article: PayloadArticle): string {
  if (!Array.isArray(article.tags) || article.tags.length === 0) return '';
  const first = article.tags[0];
  if (first && typeof first === 'object') return first.name ?? '';
  return '';
}

function getPublishedTimestamp(article: HomeArticle): number {
  if (!article.publishedDate) return 0;
  const time = Date.parse(article.publishedDate);
  return Number.isNaN(time) ? 0 : time;
}

function sortByDateThenViews(list: HomeArticle[]): HomeArticle[] {
  return [...list].sort((a, b) => {
    const dateDiff = getPublishedTimestamp(b) - getPublishedTimestamp(a);
    if (dateDiff !== 0) return dateDiff;
    const av = typeof a.viewCount === 'number' ? a.viewCount : 0;
    const bv = typeof b.viewCount === 'number' ? b.viewCount : 0;
    return bv - av;
  });
}

function sortByViewsThenDate(list: HomeArticle[]): HomeArticle[] {
  return [...list].sort((a, b) => {
    const av = typeof a.viewCount === 'number' ? a.viewCount : 0;
    const bv = typeof b.viewCount === 'number' ? b.viewCount : 0;
    if (av !== bv) return bv - av;
    return getPublishedTimestamp(b) - getPublishedTimestamp(a);
  });
}

function articleHasCategory(article: HomeArticle, categoryId: string): boolean {
  const list = Array.isArray(article.categories) ? article.categories : [];
  return list.some((cat: any) => {
    if (!cat) return false;
    if (typeof cat === 'object') { const id = (cat as any).id ?? cat; return String(id) === categoryId; }
    return String(cat) === categoryId;
  });
}

type CategoryBlock = { category: HomeCategory; articles: HomeArticle[] };

function selectHomeLayout(all: HomeArticle[], homeCategories: HomeCategory[]): {
  mainArticle?: HomeArticle;
  topArticles: HomeArticle[];
  mustReadArticles: HomeArticle[];
  popularArticles: HomeArticle[];
  categoryBlocks: CategoryBlock[];
} {
  const usedIds = new Set<string>();

  function pick(sorted: HomeArticle[], limit: number): HomeArticle[] {
    const result: HomeArticle[] = [];
    for (const a of sorted) {
      if (result.length >= limit) break;
      if (!usedIds.has(a.id)) { result.push(a); usedIds.add(a.id); }
    }
    if (result.length < limit) {
      for (const a of sorted) {
        if (result.length >= limit) break;
        if (!result.some(r => r.id === a.id)) { result.push(a); usedIds.add(a.id); }
      }
    }
    return result;
  }

  const byDate = sortByDateThenViews(all);
  const byViews = sortByViewsThenDate(all);

  const mainFlagged = sortByDateThenViews(all.filter(a => a.homeMainBlock));
  const mainArticle = mainFlagged[0] ?? byDate[0];
  if (mainArticle) usedIds.add(mainArticle.id);

  const topArticles = pick(sortByDateThenViews(all.filter(a => a.homeTop)).concat(byDate), 4);
  const mustReadArticles = pick(sortByDateThenViews(all.filter(a => a.homeMustRead)).concat(byDate), 2);
  const popularArticles = pick(byViews, 4);

  const categoryBlocks: CategoryBlock[] = [];
  for (const category of homeCategories) {
    if (categoryBlocks.length >= 2) break;
    const catArticles = sortByViewsThenDate(all.filter(a => articleHasCategory(a, category.id)));
    const blockArticles = pick(catArticles, 4);
    if (blockArticles.length > 0) categoryBlocks.push({ category, articles: blockArticles });
  }

  return { mainArticle, topArticles, mustReadArticles, popularArticles, categoryBlocks };
}

const articles = await fetchArticles();
const tags = await fetchTags();
const displayTags = tags.slice(0, 20);
const homeCategories = await fetchHomeCategories();



const latestArticles: HomeArticle[] = articles.map((article) => {
  const { url, alt } = getCoverImage(article);
  const tagName = getPrimaryTagName(article);
  const categoryName = getCategoryName(article);
  const viewCount = typeof article.viewCount === 'number' ? article.viewCount : 0;
  return {
    id: String(article.id),
    href: buildArticlePath(article),
    title: article.title ?? '',
    excerpt: article.excerpt ?? '',
    imageUrl: url,
    imageAlt: alt,
    fallbackImageUrl: PLACEHOLDER_IMAGE_URL,
    category: tagName || categoryName || defaultCategoryLabel,
    authorName: getAuthorName(article),
    publishedDate: article.publishedDate,
    viewCount,
    homeMainBlock: article.homeMainBlock ?? false,
    homeTop: article.homeTop ?? false,
    homeMustRead: article.homeMustRead ?? false,
    categories: article.categories,
  };
});

const { mainArticle, topArticles, mustReadArticles, popularArticles, categoryBlocks } =
  selectHomeLayout(latestArticles, homeCategories);

// Latest Materials: fixed 20 most recent articles sorted by date
const feedArticles = sortByDateThenViews(latestArticles).slice(0, 20);

type SiteLanguage = 'ru' | 'en';
type SiteSettings = {
  currentLanguage?: SiteLanguage;
  labels?: {
    homeMainRu?: string; homeMainEn?: string;
    homeLatestRu?: string; homeLatestEn?: string;
    homeMustReadRu?: string; homeMustReadEn?: string;
    homePopularRu?: string; homePopularEn?: string;
    homeTagsRu?: string; homeTagsEn?: string;
  };
};

let siteSettings: SiteSettings | null = null;
try {
  const res = await fetch(`${CMS_URL}/api/globals/site-settings`);
  if (res.ok) siteSettings = await res.json() as SiteSettings;
} catch (e) {}

const currentLanguage: SiteLanguage = siteSettings?.currentLanguage === 'en' ? 'en' : 'ru';
const defaultCategoryLabel = currentLanguage === 'en' ? 'Articles' : 'Статьи';
const L = (en: string | undefined, ru: string | undefined, defEn: string, defRu: string) =>
  currentLanguage === 'en' ? (en || defEn) : (ru || defRu);

const labelHomeMain    = L(siteSettings?.labels?.homeMainEn,    siteSettings?.labels?.homeMainRu,    'Top stories',        'Главное');
const labelHomeLatest  = L(siteSettings?.labels?.homeLatestEn,  siteSettings?.labels?.homeLatestRu,  'Latest Materials',   'Последние материалы');
const labelHomeMustRead= L(siteSettings?.labels?.homeMustReadEn,siteSettings?.labels?.homeMustReadRu,'Must-Read Stories',  'Must-Read Stories');
const labelHomePopular = L(siteSettings?.labels?.homePopularEn, siteSettings?.labels?.homePopularRu, 'Popular',            'Популярное');
const labelHomeTags    = L(siteSettings?.labels?.homeTagsEn,    siteSettings?.labels?.homeTagsRu,    'Tags',               'Теги');

const articleCount = articles.length;
const brandName = await getBrandName();
const metaTitle = await generateHomeTitle(articleCount, brandName);
const metaDescription = await generateHomeDescription(articleCount, brandName);
---

<BaseLayout title={metaTitle} description={metaDescription}>
  <MainColumns>
    {articles.length === 0 ? (
      <p class="text-muted text-sm py-12 text-center">No articles yet.</p>
    ) : (
      <>

        {/* ── HERO: main article + top stories sidebar ── */}
        {mainArticle && (
          <section class="home-hero">
            {/* Main featured article */}
            <a href={mainArticle.href} class="home-hero__main group">
              <div class="home-hero__img-wrap">
                <img
                  src={mainArticle.imageUrl}
                  alt={mainArticle.imageAlt}
                  width={800}
                  height={450}
                  loading="eager"
                  class="home-hero__img"
                  onerror={`this.onerror=null;this.src='${PLACEHOLDER_IMAGE_URL}'`}
                />
              </div>
              <div class="home-hero__body">
                {mainArticle.category && (
                  <span class="home-cat-tag">{mainArticle.category}</span>
                )}
                <h1 class="home-hero__title">{mainArticle.title}</h1>
                {mainArticle.excerpt && (
                  <p class="home-hero__excerpt">{mainArticle.excerpt}</p>
                )}
                <p class="home-hero__meta">{mainArticle.authorName}</p>
              </div>
            </a>

            {/* Top stories stack */}
            <div class="home-hero__stack">
              <p class="home-section-label">{labelHomeMain}</p>
              {topArticles.map((article) => (
                <a href={article.href} class="home-hero__side-item group">
                  <div class="home-hero__side-img-wrap">
                    <img
                      src={article.imageUrl}
                      alt={article.imageAlt}
                      width={120}
                      height={80}
                      loading="lazy"
                      class="home-hero__side-img"
                      onerror={`this.onerror=null;this.src='${PLACEHOLDER_IMAGE_URL}'`}
                    />
                  </div>
                  <div class="home-hero__side-body">
                    {article.category && (
                      <span class="home-cat-tag">{article.category}</span>
                    )}
                    <h3 class="home-hero__side-title">{article.title}</h3>
                    <p class="home-hero__side-meta">{article.authorName}</p>
                  </div>
                </a>
              ))}
            </div>
          </section>
        )}

        {/* ── LATEST NEWS + sidebar (Popular, Tags, Ad) ── */}
        <div class="home-two-col">

          {/* Left: latest feed */}
          <section class="home-feed" id="article-feed">
            <p class="home-section-label">{labelHomeLatest}</p>

            <div id="article-feed-grid" class="home-feed__grid">
              {feedArticles.map((article, index) => (
                <>
                  {/* Must-read banner injected after item 7 */}
                  {index === 7 && mustReadArticles.length > 0 && (
                    <div class="home-mustread">
                      <p class="home-section-label">{labelHomeMustRead}</p>
                      <div class="home-mustread__grid">
                        {mustReadArticles.map((mr) => (
                          <a href={mr.href} class="home-mustread__item group">
                            <div class="home-mustread__img-wrap">
                              <img
                                src={mr.imageUrl}
                                alt={mr.imageAlt}
                                width={480}
                                height={270}
                                loading="lazy"
                                class="home-mustread__img"
                                onerror={`this.onerror=null;this.src='${PLACEHOLDER_IMAGE_URL}'`}
                              />
                            </div>
                            {mr.category && <span class="home-cat-tag">{mr.category}</span>}
                            <h3 class="home-mustread__title">{mr.title}</h3>
                            <p class="home-mustread__meta">{mr.authorName}</p>
                          </a>
                        ))}
                      </div>
                    </div>
                  )}

                  <div class:list={['home-news-item', index >= 14 ? 'hidden' : '']} data-index={index}>
                    <a href={article.href} class="home-news-item__link group">
                      <div class="home-news-item__img-wrap">
                        <img
                          src={article.imageUrl}
                          alt={article.imageAlt}
                          width={160}
                          height={107}
                          loading="lazy"
                          class="home-news-item__img"
                          onerror={`this.onerror=null;this.src='${article.fallbackImageUrl}'`}
                        />
                      </div>
                      <div class="home-news-item__body">
                        {article.category && (
                          <span class="home-cat-tag">{article.category}</span>
                        )}
                        <h3 class="home-news-item__title">{article.title}</h3>
                        <p class="home-news-item__meta">{article.authorName}</p>
                      </div>
                    </a>
                  </div>
                </>
              ))}
            </div>

            <div class="home-feed__more-wrap">
              <button id="article-feed-more" type="button" class="home-feed__more-btn">
                {currentLanguage === 'en' ? 'Load more' : 'Показать ещё'}
              </button>
            </div>
          </section>

          {/* Right: sidebar */}
          <aside class="home-sidebar">

            {/* Popular */}
            <div class="home-sidebar__section">
              <p class="home-section-label">{labelHomePopular}</p>
              <ol class="home-popular">
                {popularArticles.map((article, i) => (
                  <li class="home-popular__item">
                    <a href={article.href} class="home-popular__link group">
                      <span class="home-popular__num">{String(i + 1).padStart(2, '0')}</span>
                      <div>
                        {article.category && (
                          <span class="home-cat-tag">{article.category}</span>
                        )}
                        <h3 class="home-popular__title">{article.title}</h3>
                      </div>
                    </a>
                  </li>
                ))}
              </ol>
            </div>

            {/* Category blocks */}
            {categoryBlocks.map((block) => (
              <div class="home-sidebar__section">
                <p class="home-section-label">
                  <a href={`/categories/${block.category.slug}`} class="hover:text-accent transition-colors">
                    {block.category.name}
                  </a>
                </p>
                <ul class="home-catblock">
                  {block.articles.map((article) => (
                    <li class="home-catblock__item">
                      <a href={article.href} class="home-catblock__link group">
                        {article.category && (
                          <span class="home-cat-tag">{article.category}</span>
                        )}
                        <h3 class="home-catblock__title">{article.title}</h3>
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            ))}

            {/* Tags */}
            <div class="home-sidebar__section">
              <p class="home-section-label">{labelHomeTags}</p>
              <div class="home-tags">
                {displayTags.map((tag) => (
                  <a href={`/tags/${tag.slug}`} class="home-tags__pill">{tag.name}</a>
                ))}
                <a href="/tags" class="home-tags__pill home-tags__pill--all">
                  {currentLanguage === 'en' ? 'All tags →' : 'Все теги →'}
                </a>
              </div>
            </div>

            {/* Ad slot */}
            <div class="home-ad-slot">
              <p class="home-ad-slot__label">Advertisement</p>
              <div class="home-ad-slot__area" id="home-sidebar-ad"></div>
            </div>

          </aside>
        </div>

      </>
    )}
  </MainColumns>
</BaseLayout>

<style>
/* ─────────────────────────────────────────
   Design tokens — match article page palette
───────────────────────────────────────── */
:root {
  --home-bg:          #faf9f7;
  --home-surface:     #ffffff;
  --home-surface2:    #f3f1ec;
  --home-text:        #1a1a18;
  --home-text2:       #4a4a45;
  --home-muted:       #8a8a82;
  --home-accent:      var(--accent, #2d6a4f);
  --home-border:      #e2ddd6;
  --home-border2:     #ccc8c0;
  --home-radius:      6px;
  --home-radius-sm:   4px;
  --home-font-serif:  'Lora', Georgia, 'Times New Roman', serif;
  --home-font-sans:   var(--font-sans, system-ui, sans-serif);
}

/* ── Section label ── */
.home-section-label {
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: var(--home-muted);
  margin-bottom: 1rem;
  padding-bottom: 0.625rem;
  border-bottom: 1px solid var(--home-border);
}

/* ── Category tag pill ── */
.home-cat-tag {
  display: inline-block;
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--home-accent);
  margin-bottom: 5px;
}

/* ─────────────────────────────────────────
   HERO
───────────────────────────────────────── */
.home-hero {
  display: grid;
  grid-template-columns: 1fr;
  gap: 0;
  border: 1px solid var(--home-border);
  border-radius: var(--home-radius);
  overflow: hidden;
  background: var(--home-surface);
  margin-bottom: 2.5rem;
}

@media (min-width: 900px) {
  .home-hero {
    grid-template-columns: minmax(0, 1.7fr) minmax(0, 1fr);
  }
}

/* Main article */
.home-hero__main {
  display: flex;
  flex-direction: column;
  text-decoration: none;
  border-bottom: 1px solid var(--home-border);
}

@media (min-width: 900px) {
  .home-hero__main {
    border-bottom: none;
    border-right: 1px solid var(--home-border);
  }
}

.home-hero__img-wrap {
  overflow: hidden;
  flex-shrink: 0;
}

.home-hero__img {
  width: 100%;
  aspect-ratio: 16 / 9;
  object-fit: cover;
  display: block;
  transition: transform 0.4s ease;
}

.home-hero__main:hover .home-hero__img {
  transform: scale(1.03);
}

.home-hero__body {
  padding: 1.25rem 1.5rem 1.5rem;
  display: flex;
  flex-direction: column;
  gap: 0;
}

.home-hero__title {
  font-family: var(--home-font-serif);
  font-size: clamp(20px, 2.5vw, 26px);
  font-weight: 600;
  line-height: 1.28;
  color: var(--home-text);
  margin: 0 0 0.625rem;
  transition: opacity 0.15s;
}

.home-hero__main:hover .home-hero__title {
  opacity: 0.8;
}

.home-hero__excerpt {
  font-size: 14px;
  color: var(--home-text2);
  line-height: 1.65;
  margin-bottom: 0.75rem;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.home-hero__meta {
  font-size: 11px;
  color: var(--home-muted);
  margin-top: auto;
}

/* Top stories stack */
.home-hero__stack {
  display: flex;
  flex-direction: column;
  padding: 1.25rem 1.25rem 0.5rem;
}

.home-hero__side-item {
  display: flex;
  gap: 12px;
  padding: 0.875rem 0;
  border-bottom: 1px solid var(--home-border);
  text-decoration: none;
  transition: opacity 0.15s;
}

.home-hero__side-item:last-child {
  border-bottom: none;
}

.home-hero__side-item:hover {
  opacity: 0.75;
}

.home-hero__side-img-wrap {
  flex-shrink: 0;
  width: 88px;
  height: 62px;
  border-radius: var(--home-radius-sm);
  overflow: hidden;
}

.home-hero__side-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 0.3s ease;
}

.home-hero__side-item:hover .home-hero__side-img {
  transform: scale(1.05);
}

.home-hero__side-body {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.home-hero__side-title {
  font-family: var(--home-font-serif);
  font-size: 14px;
  font-weight: 600;
  line-height: 1.4;
  color: var(--home-text);
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin-bottom: 4px;
}

.home-hero__side-meta {
  font-size: 11px;
  color: var(--home-muted);
  margin-top: auto;
}

/* ─────────────────────────────────────────
   TWO-COLUMN LAYOUT: feed + sidebar
───────────────────────────────────────── */
.home-two-col {
  display: grid;
  grid-template-columns: 1fr;
  gap: 2.5rem;
  align-items: start;
}

@media (min-width: 900px) {
  .home-two-col {
    grid-template-columns: minmax(0, 1fr) 280px;
    gap: 3rem;
  }
}

/* ─────────────────────────────────────────
   LATEST NEWS FEED
───────────────────────────────────────── */
.home-feed__grid {
  display: flex;
  flex-direction: column;
  gap: 0;
}

/* Individual news item */
.home-news-item {
  border-bottom: 1px solid var(--home-border);
}

.home-news-item:last-child {
  border-bottom: none;
}

.home-news-item__link {
  display: flex;
  gap: 14px;
  padding: 1rem 0;
  text-decoration: none;
  transition: opacity 0.15s;
}

.home-news-item__link:hover {
  opacity: 0.75;
}

.home-news-item__img-wrap {
  flex-shrink: 0;
  width: 110px;
  height: 74px;
  border-radius: var(--home-radius-sm);
  overflow: hidden;
}

@media (min-width: 600px) {
  .home-news-item__img-wrap {
    width: 140px;
    height: 93px;
  }
}

.home-news-item__img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 0.3s ease;
}

