</style>

<script define:vars={{ PAGE_LIMIT, PLACEHOLDER_IMAGE_URL }}>
  (function () {
    var grid = document.getElementById('article-feed-grid');
    var moreBtn = document.getElementById('article-feed-more');
    if (!grid || !moreBtn) return;

    var wrappers = Array.prototype.slice.call(grid.querySelectorAll('[data-index]'));

    if (wrappers.length < PAGE_LIMIT) {
      moreBtn.style.display = 'none';
      return;
    }

    var currentPage = 1;
    var isLoading = false;
    var hasMore = true;

    function buildArticlePath(doc) {
      var slug = doc.slug || '';
      var id = doc.id != null ? String(doc.id) : '';
      if (slug && id) return '/article/' + slug + '-' + id + '.html';
      if (slug) return '/article/' + slug;
      if (id) return '/article/' + id;
      return '/';
    }

    function getCoverImage(doc) {
      if (doc.feedImageUrl) return { url: doc.feedImageUrl, alt: doc.title || '' };
      var cover = doc.coverImage && typeof doc.coverImage === 'object' ? doc.coverImage : null;
      return { url: (cover && cover.url) || PLACEHOLDER_IMAGE_URL, alt: (cover && cover.alt) || (doc.title || '') };
    }

    function getCategoryName(doc) {
      var cats = Array.isArray(doc.categories) ? doc.categories : [];
      if (!cats.length) return '';
      var first = cats[0];
      return (first && typeof first === 'object') ? (first.name || '') : '';
    }

    function getAuthorName(doc) {
      var a = doc.author;
      return (a && typeof a === 'object') ? (a.name || 'Unknown') : 'Unknown';
    }

    function createCard(doc, index) {
      var cover = getCoverImage(doc);
      var category = getCategoryName(doc);
      var authorName = getAuthorName(doc);
      var href = buildArticlePath(doc);

      var wrap = document.createElement('div');
      wrap.className = 'home-news-item';
      wrap.setAttribute('data-index', String(index));

      var link = document.createElement('a');
      link.href = href;
      link.className = 'home-news-item__link group';

      var imgWrap = document.createElement('div');
      imgWrap.className = 'home-news-item__img-wrap';

      var img = document.createElement('img');
      img.src = cover.url;
      img.alt = cover.alt || '';
      img.width = 160;
      img.height = 107;
      img.loading = 'lazy';
      img.className = 'home-news-item__img';
      img.onerror = function () { this.onerror = null; this.src = PLACEHOLDER_IMAGE_URL; };
      imgWrap.appendChild(img);

      var body = document.createElement('div');
      body.className = 'home-news-item__body';

      if (category) {
        var cat = document.createElement('span');
        cat.className = 'home-cat-tag';
        cat.textContent = category;
        body.appendChild(cat);
      }

      var title = document.createElement('h3');
      title.className = 'home-news-item__title';
      title.textContent = doc.title || '';
      body.appendChild(title);

      var meta = document.createElement('p');
      meta.className = 'home-news-item__meta';
      meta.textContent = authorName;
      body.appendChild(meta);

      link.appendChild(imgWrap);
      link.appendChild(body);
      wrap.appendChild(link);
      return wrap;
    }

    async function loadMore() {
      if (isLoading || !hasMore) return;
      isLoading = true;
      moreBtn.disabled = true;
      try {
        var nextPage = currentPage + 1;
        var res = await fetch('/api/frontend/articles?page=' + nextPage + '&limit=' + PAGE_LIMIT);
        if (!res.ok) throw new Error('HTTP ' + res.status);
        var data = await res.json();
        var docs = Array.isArray(data.docs) ? data.docs : [];

        if (!docs.length) { hasMore = false; moreBtn.style.display = 'none'; return; }

        for (var i = 0; i < docs.length; i++) {
          var card = createCard(docs[i], wrappers.length);
          wrappers.push(card);
          grid.appendChild(card);
        }

        currentPage = typeof data.page === 'number' ? data.page : nextPage;

        if (
          (typeof data.hasNextPage === 'boolean' && !data.hasNextPage) ||
          (typeof data.totalPages === 'number' && typeof data.page === 'number' && data.page >= data.totalPages) ||
          data.nextPage == null
        ) {
          hasMore = false;
          moreBtn.style.display = 'none';
        }
      } catch (e) {
        console.error('Failed to load more articles', e);
        hasMore = false;
        moreBtn.style.display = 'none';
      } finally {
        isLoading = false;
        moreBtn.disabled = false;
      }
    }

    moreBtn.addEventListener('click', loadMore);
  })();
</script>
