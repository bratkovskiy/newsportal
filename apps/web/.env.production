# Environment for Astro frontend (web) in Docker / production
# В продакшене и внутри docker-compose фронт живёт в одной сети с CMS,
# поэтому для SSR-запросов нужно использовать сервис `cms`, а не localhost.
CMS_URL=http://cms:3000

# Публичный URL CMS (из браузера по-прежнему ходим на localhost:3000)
PUBLIC_CMS_URL=http://localhost:3000
PUBLIC_PLACEHOLDER_URL=http://localhost:3000/api/media/file/placeholder-1.jpg

# Базовый URL самого сайта (используется Astro)
SITE=http://localhost:4321
