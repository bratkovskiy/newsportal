{
  "name": "cms",
  "private": true,
  "type": "module",
  "version": "1.0.0",
  "description": "Payload CMS for the fashion news project",
  "main": "dist/server.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "serve": "next start",
    "generate:types": "payload generate:types",
    "generate:importmap": "payload generate:importmap",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "migrate": "npm run payload migrate",
    "seed:placeholder": "cross-env NODE_OPTIONS=--no-deprecation tsx src/seed-placeholder.ts",
    "ci": "npm run migrate && npm run build"
  },
  "dependencies": {
    "@payloadcms/db-postgres": "^3.0.0",
    "@payloadcms/next": "^3.0.0",
    "@payloadcms/richtext-lexical": "^3.0.0",
    "@payloadcms/ui": "^3.0.0",
    "cross-env": "^7.0.3",
    "dotenv": "^16.3.1",
    "fast-xml-parser": "^4.3.6",
    "next": "^15.2.3",
    "payload": "^3.0.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "sharp": "^0.33.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.17",
    "@types/node": "^20.0.0",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.1",
    "nodemon": "^3.0.1",
    "ts-node": "^10.9.1",
    "tsx": "^4.7.0",
    "typescript": "^5.1.6"
  }
}
