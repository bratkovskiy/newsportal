[Unit]
Description=Payload CMS Backend
After=network.target

[Service]
Type=simple
User={{ service_user_cms }}
Group={{ webapp_group }}
WorkingDirectory={{ webapp_cms_dir }}
EnvironmentFile={{ webapp_cms_env_file }}
Environment=NODE_ENV=production
Environment=PORT={{ cms_port }}
ExecStart=/usr/bin/npm start
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
