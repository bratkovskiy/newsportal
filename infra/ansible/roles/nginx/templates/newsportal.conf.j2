{% if nginx_enable_ssl | default(false) | bool %}
server {
  listen 80;
  server_name {{ nginx_server_name | default('_') }};
  return 301 https://$host$request_uri;
}

server {
  listen 443 ssl;
  server_name {{ nginx_server_name | default('_') }};

  ssl_certificate {{ remote_cf_origin_cert_file | default('/etc/nginx/ssl/cloudflare_origin.crt') }};
  ssl_certificate_key {{ remote_cf_origin_key_file | default('/etc/nginx/ssl/cloudflare_origin.key') }};

  client_max_body_size 50m;

  gzip on;
  gzip_vary on;
  gzip_proxied any;
  gzip_comp_level 6;
  gzip_min_length 1024;
  gzip_types
    text/plain
    text/css
    text/javascript
    application/javascript
    application/json
    application/xml
    application/rss+xml
    image/svg+xml;
{% else %}
server {
  listen 80;
  server_name {{ nginx_server_name | default('_') }};

  client_max_body_size 50m;

  gzip on;
  gzip_vary on;
  gzip_proxied any;
  gzip_comp_level 6;
  gzip_min_length 1024;
  gzip_types
    text/plain
    text/css
    text/javascript
    application/javascript
    application/json
    application/xml
    application/rss+xml
    image/svg+xml;
{% endif %}

  # Proxy all Payload admin routes to the CMS (Next.js app) on port 3000
  # /admin and /admin/... are handled here
  location /admin {
    proxy_pass http://127.0.0.1:3000;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
  }

  # Next.js static assets for the CMS admin (/admin) are served from /_next
  location /_next {
    proxy_pass http://127.0.0.1:3000;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
  }

  location ^~ /_next/static/ {
    proxy_pass http://127.0.0.1:3000;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;

    proxy_hide_header Cache-Control;
    expires 1y;
    add_header Cache-Control "public, max-age=31536000, immutable" always;
  }

  # Payload API (used by admin) lives on the CMS as well
  location /api {
    proxy_pass http://127.0.0.1:3000;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
  }

  location / {
    proxy_pass http://127.0.0.1:4321;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
  }

  location ^~ /_astro/ {
    proxy_pass http://127.0.0.1:4321;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;

    proxy_hide_header Cache-Control;
    expires 1y;
    add_header Cache-Control "public, max-age=31536000, immutable" always;
  }
}
