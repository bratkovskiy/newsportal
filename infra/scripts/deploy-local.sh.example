#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
ENV_FILE="${ROOT_DIR}/.env.local"

if [[ -f "${ENV_FILE}" ]]; then
  set -a
  # shellcheck disable=SC1090
  source "${ENV_FILE}"
  set +a
fi

TF_DIR="$ROOT_DIR/infra/terraform/gcp"
ANS_DIR="$ROOT_DIR/infra/ansible"
KEY_PATH="${ANSIBLE_SSH_KEY:-$HOME/.ssh/id_ed25519}"

: "${VAULT_TOKEN:?Set VAULT_TOKEN before running (export or put in .env.local)}"
export VAULT_ADDR="${VAULT_ADDR:-https://vault.your-host:8200}"
export VAULT_SKIP_VERIFY="${VAULT_SKIP_VERIFY:-true}"

# ensure SSH key is available for Terraform metadata and Ansible git clone
eval "$(ssh-agent -s)" >/dev/null
trap 'ssh-agent -k >/dev/null' EXIT
ssh-add -q "${KEY_PATH}"

TF_VARS_IN_DIR="${TF_DIR}/terraform.tfvars"
TF_VARS_PARENT="${ROOT_DIR}/infra/terraform/terraform.tfvars"
if [[ -f "${TF_VARS_IN_DIR}" ]]; then
  TF_VARS_ARG=(-var-file="${TF_VARS_IN_DIR}")
elif [[ -f "${TF_VARS_PARENT}" ]]; then
  TF_VARS_ARG=(-var-file="${TF_VARS_PARENT}")
else
  TF_VARS_ARG=()
fi

cd "$TF_DIR"
terraform init -input=false
terraform apply -auto-approve "${TF_VARS_ARG[@]}" "$@"

APP_IP="$(terraform output -raw instance_ip)"
SSH_USER="$(terraform output -raw ssh_user)"

cat > "$ANS_DIR/inventory/prod.ini" <<EOF
[web]
webapp ansible_host=${APP_IP} ansible_user=${SSH_USER} ansible_ssh_private_key_file=${KEY_PATH}
EOF

cd "$ANS_DIR"
ansible-galaxy collection install community.hashi_vault >/dev/null
ansible-playbook site.yml
