# Node / monorepo common ignores
node_modules/
.npm-cache/

# Build outputs
/dist/
/build/
/.turbo/
.next/
out/
coverage/

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# Env files
.env
.env.local
.env.*.local
.env.*
!.env.example

# Terraform local vars
*.tfvars
!**/*.tfvars.example

# Local infra helper scripts
infra/scripts/*.sh

# Editor / OS
.DS_Store
.idea/
.vscode/
*.swp
*.swo

# Docker
*.pid

# Payload CMS media (если нужно хранить только через бэкап, а не в git)
/apps/cms/src/media/

# TypeScript build caches
*.tsbuildinfo
