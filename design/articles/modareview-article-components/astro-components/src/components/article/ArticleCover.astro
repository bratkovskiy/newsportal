---
// apps/web/src/components/article/ArticleCover.astro

export interface Props {
  src: string;
  alt: string;
}
const { src, alt } = Astro.props;
---

<figure class="cover-wrap">
  <img
    src={src}
    alt={alt}
    width="1200"
    height="675"
    loading="eager"
    fetchpriority="high"
    decoding="async"
  />
</figure>

<style>
  .cover-wrap {
    margin: 0 -1.25rem 2.5rem;
  }
  .cover-wrap img {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
  }
</style>
